// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Per-butik API-nyckel för det skrivande delivery-windows-API:t.
// En aktiv nyckel per butik (shop unik). Att generera om ersätter den gamla
// (rotation). Nyckeln visas en gång i admin och lagras bara hashad.
model ApiCredential {
  id         Int      @id @default(autoincrement())
  shop       String   @unique
  hashedKey  String   // SHA-256-hash av den hemliga nyckeln
  label      String?  // valfri etikett, t.ex. "Thea" eller "Gordon"
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?
}

model DeliveryWindow {
  id                   Int      @id @default(autoincrement())

  shop                 String   // butiken som äger denna rad (multi-tenant)
  zipcode              String?  // null = gäller alla postnummer (t.ex. utlämningsställen)
  deliveryDate         DateTime @db.Date
  packDate             DateTime @db.Date
  stopDate             DateTime @db.Date
  homeDelivery         Boolean
  deliveryLocationId   Int
  deliveryLocationName String

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([shop, zipcode, deliveryDate, deliveryLocationId])
  @@index([shop, zipcode])
}
