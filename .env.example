# ---------------------------------------------------------------------------
# Gröna Gårdar delivery widget — environment variables
#
# Locally (`shopify app dev`) the Shopify CLI injects SHOPIFY_API_KEY,
# SHOPIFY_API_SECRET and SHOPIFY_APP_URL automatically.
#
# In production you must set ALL of the variables in this file as service
# environment variables. Local development should use `shopify app dev`.
# ---------------------------------------------------------------------------

# --- Shopify (required in production) -------------------------------------
# From Shopify Partners -> Apps -> delivery-public-app -> API credentials.
SHOPIFY_API_KEY=1d9bb7f18eaa29792435405a90cb30ef
SHOPIFY_API_SECRET=your_app_client_secret
# The public URL of the deployed server, no trailing slash.
SHOPIFY_APP_URL=https://APP_DOMAIN.example
# Required to activate the checkout validation and delivery customization
# Functions. Must match access_scopes in shopify.app.toml.
SCOPES=write_validations,write_delivery_customizations

# --- Database -------------------------------------------------------------
# Postgres connection string.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- External delivery windows API ---------------------------------------
# No global key. Each shop generates its own key in the app admin; POST
# /api/delivery-windows resolves the shop from the Bearer token (ApiCredential).

# --- Listing / compliance -------------------------------------------------
# Contact email shown on the public privacy policy page (/privacy). Must not
# contain the word "shopify". Use your own support address.
APP_CONTACT_EMAIL=support@your-domain.com
